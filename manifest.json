{
  "manifest_version": 3,
  "name": "Metin Tamamlayıcı",
  "version": "1.1.1",
  "default_locale": "en",
  "description": "Kayıtlı metinlerden yazıyı tamamlar.",
  "permissions": ["storage", "scripting"],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": ["<all_urls>"],
  "options_page": "settings.html"
}
